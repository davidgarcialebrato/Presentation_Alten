<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>David Garcia Lebrato - ALTEN Toulouse Interview Presentation</title>
    <style>
        :root {
            --primary: #0f2537;      /* Aero Deep Blue */
            --secondary: #1d3d54;    /* Slate Blue */
            --accent: #00a8cc;       /* Cyan / Tech Accent */
            --bg-light: #f4f7f9;     /* Soft Light Grey */
            --text-dark: #2c3e50;    /* Charcoal Text */
            --text-light: #ffffff;   /* White */
            --card-bg: #ffffff;      /* White Cards */
            --border-color: #d1dbe5; /* Subtle Borders */
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #111;
            color: var(--text-dark);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            padding: 40px 20px;
            min-height: 100vh;
        }

        .presentation-container {
            width: 100%;
            max-width: 1100px;
        }

        /* Slide Layout and Aspect Ratio (16:9 feel) */
        .slide {
            background: var(--bg-light);
            border-radius: 8px;
            box-shadow: 0 12px 40px rgba(0,0,0,0.5);
            width: 100%;
            min-height: 620px;
            margin-bottom: 60px;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            border: 1px solid rgba(255,255,255,0.1);
        }

        /* Slide Header Banner */
        .slide-header {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: var(--text-light);
            padding: 25px 40px;
            position: relative;
            border-bottom: 4px solid var(--accent);
        }

        .slide-header h2 {
            font-size: 24pt;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .slide-header .slide-counter {
            position: absolute;
            right: 40px;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.1);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 10pt;
            color: var(--accent);
            border: 1px solid rgba(0,168,204,0.3);
        }

        /* Slide Content Area */
        .slide-content {
            padding: 40px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        /* Slide Footer */
        .slide-footer {
            padding: 15px 40px;
            background: #eef2f5;
            border-top: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 9pt;
            color: #7f8c8d;
        }

        .slide-footer .alten-tag {
            color: var(--secondary);
            font-weight: bold;
        }

        /* Grid Frameworks */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            height: 100%;
        }

        .grid-3 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 20px;
            height: 100%;
        }

        /* Typography & General Components */
        p.intro-text {
            font-size: 11pt;
            line-height: 1.6;
            color: #4f5f6f;
            margin-bottom: 20px;
            font-style: italic;
            border-left: 3px solid var(--accent);
            padding-left: 12px;
        }

        h3 {
            font-size: 14pt;
            color: var(--primary);
            margin-bottom: 15px;
            border-bottom: 2px solid var(--border-color);
            padding-bottom: 5px;
            display: flex;
            align-items: center;
        }

        ul {
            list-style: none;
        }

        ul li {
            position: relative;
            padding-left: 20px;
            margin-bottom: 10px;
            font-size: 11pt;
            line-height: 1.5;
            color: var(--text-dark);
        }

        ul li::before {
            content: "■";
            position: absolute;
            left: 0;
            color: var(--accent);
            font-size: 8pt;
            top: 2px;
        }

        /* Unique Cards & Boxes */
        .card {
            background: var(--card-bg);
            border-radius: 6px;
            padding: 20px;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }

        .learning-box {
            background: #e6f7fa;
            border-left: 5px solid var(--accent);
            padding: 15px 20px;
            border-radius: 0 6px 6px 0;
            margin-top: auto;
        }

        .learning-box h4 {
            color: var(--secondary);
            font-size: 11pt;
            margin-bottom: 5px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .learning-box p {
            font-size: 10.5pt;
            color: var(--text-dark);
            line-height: 1.5;
        }

        /* Specific Elements for Slide 1 */
        .profile-title h1 {
            font-size: 26pt;
            color: var(--primary);
            line-height: 1.2;
        }
        .profile-title h4 {
            font-size: 13pt;
            color: var(--accent);
            margin-top: 5px;
            font-weight: 500;
        }
        .lang-badge {
            display: inline-block;
            background: var(--primary);
            color: white;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 9.5pt;
            margin-right: 5px;
            margin-top: 5px;
        }

        /* Callout Big Banner */
        .objective-banner {
            background: var(--primary);
            color: white;
            padding: 20px;
            border-radius: 6px;
            margin-top: auto;
            border-right: 4px solid var(--accent);
        }
        .objective-banner h4 {
            color: var(--accent);
            text-transform: uppercase;
            font-size: 10pt;
            margin-bottom: 5px;
            letter-spacing: 1px;
        }
        .objective-banner p {
            font-size: 11pt;
            font-style: italic;
        }

        /* Responsive Fixes */
        @media (max-width: 850px) {
            .grid-2, .grid-3 {
                grid-template-columns: 1fr;
            }
            .slide {
                min-height: auto;
            }
        }
    </style>
</head>
